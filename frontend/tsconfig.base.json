{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2017",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@passion-market/ui": ["packages/ui/src/index.ts"],
      "@passion-market/ui/*": ["packages/ui/src/*"],
      "@passion-market/api-client": ["packages/api-client/src/index.ts"],
      "@passion-market/api-client/*": ["packages/api-client/src/*"],
      "@passion-market/hooks": ["packages/hooks/src/index.ts"],
      "@passion-market/hooks/*": ["packages/hooks/src/*"]
    }
  }
}
